#!/usr/bin/perl
# check-parens - verify parentheses/brackets are balanced in Scheme files
use strict;
use warnings;

my $file = $ARGV[0] or die "Usage: check-parens <file>\n";
open my $fh, '<', $file or die "Cannot open $file: $!\n";

my $depth = 0;
my $sq_depth = 0;
my $line_num = 0;
my @paren_stack;  # track (line, char) for each open paren
my @sq_stack;
my $errors = 0;

while (my $line = <$fh>) {
    $line_num++;
    chomp $line;

    # strip ;-comments (but not inside strings)
    my $code = '';
    my $in_string = 0;
    my $escaped = 0;

    for my $i (0 .. length($line) - 1) {
        my $ch = substr($line, $i, 1);

        if ($escaped) {
            $code .= $ch;
            $escaped = 0;
            next;
        }

        if ($ch eq '\\') {
            $code .= $ch;
            $escaped = 1;
            next;
        }

        if ($ch eq '"') {
            $in_string = !$in_string;
            $code .= $ch;
            next;
        }

        if (!$in_string && $ch eq ';') {
            last;  # rest of line is comment
        }

        $code .= $ch;
    }

    if ($in_string) {
        # string continues to next line, that's fine for multiline strings
        # but we still count parens in the non-string portion above
    }

    # count parens in code portion
    for my $i (0 .. length($code) - 1) {
        my $ch = substr($code, $i, 1);

        # skip chars inside strings
        # (we already stripped comments, but strings may contain parens)
        # re-parse for string awareness
    }

    # simpler approach: parse with string awareness
    $in_string = 0;
    $escaped = 0;
    for my $i (0 .. length($code) - 1) {
        my $ch = substr($code, $i, 1);

        if ($escaped) {
            $escaped = 0;
            next;
        }
        if ($ch eq '\\') {
            $escaped = 1;
            next;
        }
        if ($ch eq '"') {
            $in_string = !$in_string;
            next;
        }
        next if $in_string;

        if ($ch eq '(') {
            push @paren_stack, $line_num;
            $depth++;
        } elsif ($ch eq ')') {
            if ($depth <= 0) {
                print STDERR "$file:$line_num: unmatched closing parenthesis\n";
                $errors++;
            } else {
                pop @paren_stack;
                $depth--;
            }
        } elsif ($ch eq '[') {
            push @sq_stack, $line_num;
            $sq_depth++;
        } elsif ($ch eq ']') {
            if ($sq_depth <= 0) {
                print STDERR "$file:$line_num: unmatched closing bracket\n";
                $errors++;
            } else {
                pop @sq_stack;
                $sq_depth--;
            }
        }
    }
}

close $fh;

if ($depth > 0) {
    for my $ln (@paren_stack) {
        print STDERR "$file:$ln: unclosed parenthesis ($depth remaining)\n";
    }
    $errors++;
}

if ($sq_depth > 0) {
    for my $ln (@sq_stack) {
        print STDERR "$file:$ln: unclosed bracket ($sq_depth remaining)\n";
    }
    $errors++;
}

if ($errors) {
    print STDERR "$file: $errors paren/bracket error(s) found\n";
    exit 1;
}

exit 0;
